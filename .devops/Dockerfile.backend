ARG CUDA=0

FROM python:3.11-slim AS base-0

FROM nvidia/cuda:12.4.1-cudnn9-runtime-ubuntu22.04 AS base-1
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.11 python3.11-dev python3-pip curl git build-essential \
    && ln -sf python3.11 /usr/bin/python3 \
    && ln -sf python3.11 /usr/bin/python \
    && pip3 install --upgrade pip \
    && rm -rf /var/lib/apt/lists/*


FROM base-${CUDA} AS deps
ARG CUDA=0
ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential curl git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --upgrade pip

WORKDIR /app

# Copy requirements but REMOVE bare torch line — we install it explicitly below
COPY backend/requirements.txt ./requirements.txt
RUN grep -v "^torch" requirements.txt > requirements.clean.txt

# Install everything except torch
RUN pip install --no-cache-dir -r requirements.clean.txt

# Install correct torch based on CUDA arg
RUN if [ "$CUDA" = "1" ]; then \
        pip install --no-cache-dir \
            torch==2.3.1 \
            torchvision==0.18.1 \
            --index-url https://download.pytorch.org/whl/cu121; \
    else \
        pip install --no-cache-dir \
            torch==2.3.1+cpu \
            torchvision==0.18.1+cpu \
            --index-url https://download.pytorch.org/whl/cpu; \
    fi


FROM deps AS final

LABEL org.opencontainers.image.title="Quadtrix Python Backend"
LABEL org.opencontainers.image.description="FastAPI + PyTorch inference layer"
LABEL org.opencontainers.image.source="https://github.com/Eamon2009/Quadtrix.cpp"

WORKDIR /app
COPY backend/ ./backend/
COPY engine/  ./engine/
RUN mkdir -p /models /app/engine/logs

VOLUME ["/models"]

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    TORCH_CHECKPOINT_PATH=/models/best_model.pt \
    API_PORT=3001 \
    LOG_LEVEL=INFO \
    CORS_ORIGINS=http://localhost:5173

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
    CMD curl -f http://localhost:3001/api/health || exit 1

WORKDIR /app/backend
CMD ["python", "-m", "uvicorn", "main:app", \
    "--host", "0.0.0.0", \
    "--port", "3001", \
    "--workers", "1"]
