# =============================================================================
# Quadtrix.cpp — Frontend Dev Server (Vite)
# Used ONLY in docker-compose.dev.yml — not for production
# =============================================================================

FROM node:20-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --prefer-offline

COPY frontend/ ./

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
